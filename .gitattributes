# Auto detect text files and normalize line endings to LF
* text=auto

# Source code
*.cs text eol=lf
*.tsx text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.md text eol=lf

# Binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
